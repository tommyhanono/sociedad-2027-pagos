# Variables de entorno del frontend.
# Local: copiá este archivo a `.env` y completá los valores.
# Vercel: seteá estas mismas variables en Project Settings → Environment Variables.
#
# Ninguna es un secreto de servidor: la anon key de Supabase está diseñada para ir en el
# cliente (queda protegida por RLS en la base). Los datos ACH son públicos (los ve la mamá).

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_publica

VITE_ACH_BANCO=Credicorp Bank
VITE_ACH_CUENTA=4021-973-201
VITE_ACH_TIPO=Cuenta de Ahorros
VITE_ACH_BENEFICIARIO=Margie Hanono o Esther Davarro
